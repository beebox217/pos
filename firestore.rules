rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.role;
    }

    function isManagerOrAdmin() {
      return isSignedIn() && (userRole() in ['系統管理員', '店長']);
    }

    match /accounts/{accountId} {
      allow read, write: if isSignedIn();
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() || resource.data.publicReceipt == true;
      allow list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /purchases/{purchaseId} {
      allow read, write: if isManagerOrAdmin();
    }

    match /categories/{categoryId} {
      allow read, write: if isSignedIn();
    }

    match /brands/{brandId} {
      allow read, write: if isSignedIn();
    }

    match /products/{productId} {
      allow read, write: if isSignedIn();
    }

    match /discounts/{discountId} {
      allow read, write: if isManagerOrAdmin();
    }

    match /payments/{paymentId} {
      allow read, write: if isManagerOrAdmin();
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isManagerOrAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
